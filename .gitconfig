[commit]
	gpgsign = true

[credential]
  helper = osxkeychain
[user]
  name =
	email =
	signingkey =
[color]
  ui = auto
[color "diff"]
  meta = blue bold
  frag = yellow reverse dim
  old = red bold
  new = green bold
[color "status"]
  added = green reverse bold
  changed = white red
  untracked = magenta
[color "branch"]
  current = yellow reverse
  local = yellow
  remote = blue
[alias]
  d = diff
  ci = commit -am
  cm = commit -m
  commitia = commit -v -a
  co = checkout
  cp = cherry-pick
  l = log
  ll = log -p
  lt = log trunk..
  llt = log -p trunk..
  lm = log master..
  llm = log -p master..
  b = branch
  ui = auto
  lg = log --all --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
  st = status
[core]
  editor = /usr/bin/vim
[push]
	default = simple
[gpg]
	program = /opt/homebrew/bin/gpg
	format = ssh
